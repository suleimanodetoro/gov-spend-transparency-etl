# --- Python ---
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.python-version

# --- Pipeline artefacts (regenerated by `make data` / `make run`) ---
data/
output/
src.zip

# --- Captures: keep curated screenshots, ignore bulky raw recordings ---
captures/**/*.mov
captures/**/*.mp4

# --- Terraform (NEVER commit state or local overrides; they can hold secrets) ---
# NB: .terraform.lock.hcl IS committed (pins provider versions for reproducibility).
aws/terraform/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
*.auto.tfvars
terraform.tfvars

# --- Credentials / secrets (defence in depth) ---
*.pem
*.key
.env
.env.*
aws-credentials*
*secret*

# --- Local-only materials (kept off the public repo on purpose) ---
deck/
prep/
PROGRESS.md
HANDOFF_REPORT.md

# --- OS / editor noise ---
~$*.pptx
.DS_Store
.idea/
.vscode/
*.swp
